if element is Swap  

<|ref|>text<|/ref|><|det|>[[160, 485, 435, 498]]<|/det|>
swap = ENCODE([LRO, LRI, RLO, LRI,  

<|ref|>text<|/ref|><|det|>[[275, 500, 434, 512]]<|/det|>
element.one, PDI, LRI,  

<|ref|>text<|/ref|><|det|>[[275, 515, 435, 527]]<|/det|>
