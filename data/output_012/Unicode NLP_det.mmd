Algorithm 2: Generation of \(2^{n - 1}\) visually identical strings via Unicode reorderings.  

<|ref|>text<|/ref|><|det|>[[108, 132, 485, 161]]<|/det|>
Input: string \(x\) of length \(n\) Result: Set of \(2^{n - 1}\) visually identical reorderings of \(x\)  

<|ref|>text<|/ref|><|det|>[[108, 179, 405, 235]]<|/det|>
struct { string one, two; } Swap string PDF := 0x202C, LRO := 0x202D string RLO := 0x202E, PDI := 0x2069 string LRI := 0x2066  

<|ref|>text<|/ref|><|det|>[[108, 250, 500, 400]]<|/det|>
procedure SWAPS (body, prefix, suffix) Set orderings := { concatenate(prefix, body, suffix) } for \(i := 0\) to length(body)- 1 do Swap swap := { body[i+1], body[i] } orderings.add([prefix, body[i], swap, body[i+1], suffix]) orderings.union(SWAPS(suffix, [prefix, swap], null)) orderings.union(SWAPS([prefix, swap], null, suffix)) end for return orderings  

<|ref|>text<|/ref|><|det|>[[110, 396, 240, 409]]<|/det|>
end procedure  

<|ref|>text<|/ref|><|det|>[[110, 425, 320, 440]]<|/det|>
